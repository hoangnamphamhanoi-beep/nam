def count_line(file_path):
    count = 0
    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            for line in f:
                if line.strip(): 
                    count += 1
        print(f'File: {file_path} has {count} lines')
        return count
    except FileNotFoundError:
        print(f'Error: File "{file_path}" not found.')
        return 0

def key_word(file_path, keyword):
    line_numbers = []
    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            for line_num, content in enumerate(f, start=1):
                if keyword.lower() in content.lower():
                    line_numbers.append(line_num)
    except FileNotFoundError:
        print(f"Error: File {file_path} not found.")
    return line_numbers

def calculate_average(file_path):
    total_score = 0
    student_count = 0
    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line and ',' in line:
                    parts = line.split(',')
                    try:
                        score = float(parts[1])
                        total_score += score
                        student_count += 1
                    except (ValueError, IndexError):
                        continue
        
        if student_count > 0:
            avg = total_score / student_count
            print(f'Average score of {student_count} students: {avg:.2f}')
        else:
            print("No valid data found.")
    except FileNotFoundError:
        print(f"Error: File {file_path} not found.")

# 4. Caesar Cipher
def caesar(filepath, steps, direction):
    shift = steps if direction == 'right' else -steps

    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            content = f.read()
        
        result = ""
        for char in content:
            if char.isdigit():
                result += char
            elif char.isupper():
                result += chr((ord(char) + shift - 65) % 26 + 65)
            elif char.islower():
                result += chr((ord(char) + shift - 97) % 26 + 97)
            else:
                result += char

        with open('ciphertext.txt', 'w', encoding='utf-8') as f_out:
            f_out.write(result)
        print("Ciphertext saved to ciphertext.txt")
        
    except FileNotFoundError:
        print(f"Error: File {filepath} not found.")

